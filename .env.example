# TraceVector environment configuration
# Copy this file to `.env` and adjust values for your environment.

# --- Application ---
TV_ENVIRONMENT=development
TV_LOG_LEVEL=INFO
TV_SECRET_KEY=change-me-in-production
TV_ALLOW_ONLINE=false

# --- PostgreSQL (metadata) ---
TV_POSTGRES_URL=postgresql+asyncpg://tracevector:tracevector@localhost:5432/tracevector

# --- ClickHouse (events) ---
TV_CLICKHOUSE_URL=http://localhost:8123
TV_CLICKHOUSE_DATABASE=tracevector
TV_CLICKHOUSE_USERNAME=default
TV_CLICKHOUSE_PASSWORD=

# --- Qdrant (vectors) ---
TV_QDRANT_URL=http://localhost:6333
TV_QDRANT_COLLECTION_PREFIX=tracevector
# Set to a directory path to use Qdrant local mode instead of a server
# TV_QDRANT_PATH=

# --- Embeddings ---
TV_EMBEDDING_MODEL=all-MiniLM-L6-v2
TV_EMBEDDING_DEVICE=cpu
TV_EMBEDDING_BATCH_SIZE=64
# Set TV_EMBEDDING_API_BASE_URL to use a remote OpenAI-compatible embeddings
# endpoint instead of the local model. TV_EMBEDDING_MODEL is sent as the
# request's "model" field.
# TV_EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# TV_EMBEDDING_API_KEY=

# --- Authentication: admin bootstrap ---
# On first startup, if no users exist yet, an administrator account is
# seeded with these credentials. The admin is forced to change the password
# on first login, which invalidates TV_ADMIN_PASSWORD immediately after —
# treat it as a one-time bootstrap secret, not a long-lived credential.
TV_ADMIN_USERNAME=admin
# TV_ADMIN_PASSWORD=

# --- Authentication: sessions ---
TV_SESSION_TTL_HOURS=168
TV_AUTH_COOKIE_NAME=tv_session
# Set to true when serving over HTTPS (required for the cookie to be sent).
TV_AUTH_COOKIE_SECURE=false
TV_AUTH_COOKIE_SAMESITE=lax

# --- Authentication: audit log ---
TV_AUDIT_ENABLED=true

# --- Authentication: optional OIDC (Authentik, Nextcloud, or any OIDC IdP) ---
# New OIDC logins are auto-provisioned into a team-less "default pool"
# (visible only to themselves) until an admin assigns them to a team.
TV_OIDC_ENABLED=false
# TV_OIDC_ISSUER=https://auth.example.org/application/o/tracevector/
# TV_OIDC_CLIENT_ID=
# TV_OIDC_CLIENT_SECRET=
# TV_OIDC_SCOPES=openid email profile
# TV_OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback
